<Page x:Class="EODHistoricalDataDownloader.View.EndOfDayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:vm="clr-namespace:EODHistoricalDataDownloader.ViewModel"
       xmlns:view="clr-namespace:EODHistoricalDataDownloader.View"
       xmlns:convert="clr-namespace:EODHistoricalDataDownloader.Converters"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EndOfDayPage"
      Style="{DynamicResource PageStyle}" >

    <Page.DataContext>
        <vm:EndOfDayPageVM/>
    </Page.DataContext>

    <Page.Resources>
        <convert:StatusIconConverter x:Key="StatusIconConverter" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Groups list -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource GraphiteMainSolid}">
            <DockPanel>
                <Button DockPanel.Dock="Bottom"
                        Margin="4"
                        Style="{DynamicResource ButtonPage}"
                        Command="{Binding AddGroup}"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource cloud_addStyle0}"/>
                        <TextBlock Text="Add Group" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>
                </Button>

                <ListBox ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="10" Opacity="0.6"
                                             Text="{Binding TickerCount, StringFormat='{}{0} tickers'}"/>
                                    <TextBlock Text="{Binding GroupStatus}" FontSize="10" Opacity="0.7">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GroupStatus}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" VerticalAlignment="Top"
                                        Style="{DynamicResource DeleteTicker}"
                                        Command="{Binding DeleteGroup}"
                                        Cursor="Hand" Margin="2,0,0,0">
                                    <TextBlock FontSize="9">X</TextBlock>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Column 1: Tickers control for selected group -->
        <view:TikersLoadingControl Grid.Column="1"
                                   DataContext="{Binding SelectedGroup.TikersLoadingControlVM}"/>

        <!-- Column 2: Settings panel for selected group -->
        <StackPanel Grid.Column="2" Orientation="Vertical"
                    DataContext="{Binding SelectedGroup}">

            <Label Margin="0,4,0,0">Group name:</Label>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>

            <Label Margin="0,4,0,0">Period:</Label>
            <ComboBox ItemsSource="{Binding ListOfPeriod}" SelectedItem="{Binding Period}"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="4,4,0,0"
                          Content="Update"
                          IsChecked="{Binding IsUpdate}"/>
            </StackPanel>

            <Label Margin="0,4,0,0">From:</Label>
            <DatePicker SelectedDate="{Binding DateFrom}"
                        SelectedDateFormat="Long"/>
            <Label Margin="0,4,0,0">To:</Label>
            <DatePicker SelectedDate="{Binding DateTo}"
                        SelectedDateFormat="Long"/>

            <Label Margin="0,4,0,0" Content="Save path:" HorizontalContentAlignment="Left"/>
            <WrapPanel Orientation="Horizontal">
                <TextBox Width="170" Text="{Binding FilePath}"/>
                <Button Margin="4"
                        Cursor="Hand"
                        Style="{DynamicResource LoadButton}"
                        Command="{Binding SelectFilePath}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource folder_openStyle0}"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <StackPanel Margin="0,4,0,0">
                <Label>CSV format:</Label>
                <ComboBox ItemsSource="{Binding ListOfFormat}" SelectedItem="{Binding Format}"/>
            </StackPanel>

            <StackPanel Margin="0,4,0,0">
                <Label>Price adjustment:</Label>
                <ComboBox ItemsSource="{Binding ListOfAdjusted}" SelectedItem="{Binding AdjustedChoice}"/>
            </StackPanel>

            <StackPanel Margin="0,4,0,0">
                <Label>Tickers merging:</Label>
                <ComboBox ItemsSource="{Binding ListOfOutput}" SelectedItem="{Binding Output}"/>
            </StackPanel>

            <!-- Buttons bound to page-level VM -->
            <StackPanel Margin="0,4,0,0"
                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">

                <Button HorizontalAlignment="Stretch" Margin="4"
                        Style="{DynamicResource LoadButton}"
                        Command="{Binding LoadToCsvFiles}"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource downloadStyle0}"/>
                        <TextBlock Text="Download group" VerticalAlignment="Center" Margin="0,6,6,6"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch" Margin="4"
                        Style="{DynamicResource LoadButton}"
                        Command="{Binding LoadAllGroups}"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource downloadStyle0}"/>
                        <TextBlock Text="Download all groups" VerticalAlignment="Center" Margin="0,6,6,6"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Center" Margin="4,4,4,4"
                        Style="{DynamicResource StopButton}"
                        Command="{Binding CancelSavingFiles}"
                        Visibility="Visible"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Stop" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,6,6,6"/>
                        <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource stopStyle0}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
