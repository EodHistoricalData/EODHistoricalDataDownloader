<Page x:Class="EODHistoricalDataDownloader.View.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:vm="clr-namespace:EODHistoricalDataDownloader.ViewModel"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage"
      Style="{DynamicResource PageStyle}" >

    <Page.DataContext>
        <vm:SettingsPageVM/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#EAEAEA"/>
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="16"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0" Content="API key: " HorizontalContentAlignment="Right" Grid.Row="1"/>
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
            <TextBox Margin="5" Width="300" HorizontalAlignment="Left"
                     Text="{Binding APIKey, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"
                       Visibility="{Binding HasApiKey, Converter={StaticResource BoolToVis}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="✓ Saved"/>
                        <Setter Property="Foreground" Value="#1F8B4C"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ApiKeyState}" Value="Saving">
                                <Setter Property="Text" Value="⟳ Saving…"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <Label Grid.Column="0" Content="Simultaneous connections: " HorizontalContentAlignment="Right" Grid.Row="2"/>
        <CheckBox Grid.Column="1" Grid.Row="2" Margin="7" VerticalAlignment="Center"
                  IsChecked="{Binding TwoConnections}"/>

        <Label Grid.Column="0" Content="Use proxy: " HorizontalContentAlignment="Right" Grid.Row="3"/>
        <CheckBox Name="cbx_UseProxy" Grid.Column="1" Grid.Row="3" Margin="7" IsChecked="{Binding UseProxy}"/>

        <Label Grid.Column="0" Content="IP address/name and port number:" HorizontalContentAlignment="Right" Grid.Row="4" VerticalAlignment="Stretch"
               IsEnabled="{Binding UseProxy}"/>
        <StackPanel Grid.Column="1" Grid.Row="4" IsEnabled="{Binding UseProxy}">
            <TextBox Margin="5,0,0,0" HorizontalAlignment="Left" Width="300" Text="{Binding ProxyHost}" VerticalAlignment="Top" HorizontalContentAlignment="Left"/>
            <Label Content="Example: localhost: 8080" IsManipulationEnabled="True" Background="Transparent"/>
        </StackPanel>

        <Label Grid.Column="0" Content="With credentials" HorizontalContentAlignment="Right" Grid.Row="5" VerticalAlignment="Stretch"/>
        <CheckBox Grid.Column="1" Grid.Row="5" Margin="7" IsChecked="{Binding WithCredentials}"/>

        <Label Grid.Column="0" Grid.Row="6" Content="Username:" IsManipulationEnabled="True" HorizontalContentAlignment="Right"
               IsEnabled="{Binding WithCredentials}"/>
        <TextBox Grid.Column="1" Grid.Row="6" Margin="5" Width="300" HorizontalContentAlignment="Left" HorizontalAlignment="Left"
                 IsEnabled="{Binding WithCredentials}"
                 Text="{Binding ProxyUsername}"/>

        <Label Grid.Column="0" Grid.Row="7" Content="Password:" IsManipulationEnabled="True" HorizontalContentAlignment="Right"
               IsEnabled="{Binding WithCredentials}"/>
        <TextBox Grid.Column="1" Grid.Row="7" Margin="5" Width="300" HorizontalContentAlignment="Left" HorizontalAlignment="Left"
                 IsEnabled="{Binding WithCredentials}"
                 Text="{Binding ProxyPassword}"/>
        <Button Grid.Column="1" Grid.Row="8"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="5"
                Style="{DynamicResource LoadButton}"
                Command="{Binding SaveSettings}"
                Cursor="Hand">
            <StackPanel Orientation="Horizontal" >
                <Path Style="{DynamicResource MenuIcon}" Data="{DynamicResource saveStyle0}"  />
                <TextBlock Text="Save" VerticalAlignment="Center" Margin="0,0,10,0"/>
            </StackPanel>
        </Button>
    </Grid>
</Page>
